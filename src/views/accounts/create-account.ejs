<div class="flex min-h-screen">
    <%- include('../partials/sidebar') %>
    <div class="flex-1 p-8">
        <div class="max-w-2xl mx-auto bg-white rounded-[2rem] shadow-sm border border-slate-100 p-10">
            <div class="mb-8">
                <h2 class="text-3xl font-bold text-slate-900">Open New Account</h2>
                <p class="text-slate-500 mt-2">Create a secure digital account in seconds.</p>
            </div>

            <form action="/api/accounts/" method="POST" data-remote class="space-y-8">
                <div class="bg-blue-50 p-6 rounded-2xl border border-blue-100">
                    <div class="flex items-center gap-4">
                        <div class="p-3 bg-blue-600 text-white rounded-xl">
                            <i data-lucide="shield-check"></i>
                        </div>
                        <div>
                            <p class="font-bold text-blue-900">Identity Verified</p>
                            <p class="text-sm text-blue-700">Your account will be linked to: <%= user.email %></p>
                        </div>
                    </div>
                </div>

                <div class="space-y-4">
                    <label class="block text-sm font-bold text-slate-700">Account Type</label>
                    <div class="grid grid-cols-2 gap-4">
                        <label class="relative flex flex-col p-4 border-2 rounded-2xl cursor-pointer hover:border-blue-500 transition border-blue-500 bg-blue-50/50">
                            <input type="radio" name="accountType" value="SAVINGS" checked class="absolute opacity-0">
                            <span class="font-bold text-blue-900">Savings</span>
                            <span class="text-xs text-blue-600 mt-1">Earn interest on balance</span>
                        </label>
                        <label class="relative flex flex-col p-4 border-2 rounded-2xl cursor-pointer hover:border-blue-500 transition border-slate-100">
                            <input type="radio" name="accountType" value="CURRENT" class="absolute opacity-0">
                            <span class="font-bold text-slate-900">Current</span>
                            <span class="text-xs text-slate-500 mt-1">Zero limits on transfers</span>
                        </label>
                    </div>
                </div>

                <button type="submit" class="w-full bg-slate-900 text-white font-bold py-4 rounded-2xl hover:bg-blue-600 transition-all shadow-xl shadow-blue-100 flex justify-center items-center gap-2">
                    <i data-lucide="sparkles" class="w-5 h-5"></i>
                    Confirm & Open Account
                </button>
            </form>
        </div>
    </div>
</div>