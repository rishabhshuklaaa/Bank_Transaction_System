<div class="flex min-h-screen bg-[#f8fafc]">
    <%- include('../partials/sidebar') %>

    <div class="flex-1 overflow-y-auto">
        <%- include('../partials/navbar') %>

        <main class="p-8 max-w-5xl mx-auto">
            <div class="flex items-center gap-4 mb-8">
                <a href="/accounts" class="p-2 bg-white border border-slate-200 rounded-xl hover:bg-slate-50 transition-all">
                    <i data-lucide="arrow-left" class="w-5 h-5 text-slate-600"></i>
                </a>
                <div>
                    <h2 class="text-3xl font-black text-slate-800 tracking-tight">Account Details</h2>
                    <p class="text-slate-500 font-medium">Detailed audit and information for A/C ****<%= account._id.toString().slice(-4) %></p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10">
                <div class="md:col-span-2 bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100 relative overflow-hidden">
                    <div class="relative z-10">
                        <div class="flex justify-between items-center mb-6">
                            <span class="px-4 py-1.5 bg-indigo-50 text-indigo-600 text-[10px] font-black uppercase tracking-widest rounded-full">
                                <%= account.accountType %> Account
                            </span>
                            <span class="text-xs font-mono text-slate-400">Created: <%= new Date(account.createdAt).toLocaleDateString() %></span>
                        </div>
                        
                        <div class="space-y-1">
                            <p class="text-slate-400 text-sm font-bold uppercase tracking-wider">Total Available Balance</p>
                            <h3 class="text-5xl font-black text-slate-900">₹<%= (account.balance || 0).toLocaleString() %></h3>
                        </div>

                        <div class="mt-10 grid grid-cols-2 gap-6 pt-8 border-t border-slate-50">
                            <div>
                                <p class="text-[10px] font-black text-slate-400 uppercase">Account Holder</p>
                                <p class="text-lg font-bold text-slate-800"><%= user.name %></p>
                            </div>
                            <div>
                                <p class="text-[10px] font-black text-slate-400 uppercase">Account Status</p>
                                <p class="text-lg font-bold text-emerald-600 flex items-center gap-1">
                                    <span class="w-2 h-2 bg-emerald-500 rounded-full"></span> <%= account.status || 'Active' %>
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="absolute -right-12 -bottom-12 w-40 h-40 bg-indigo-50 rounded-full blur-3xl opacity-60"></div>
                </div>

                <div class="bg-slate-900 p-8 rounded-[2.5rem] shadow-xl text-white flex flex-col justify-between">
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Account Reference ID</p>
                        <div class="bg-white/10 p-4 rounded-2xl break-all">
                            <p class="font-mono text-sm leading-relaxed"><%= account._id %></p>
                        </div>
                        <p class="mt-4 text-xs text-slate-500 leading-relaxed italic">Share this ID to receive money from other SkyBank users.</p>
                    </div>
                    <button onclick="navigator.clipboard.writeText('<%= account._id %>'); alert('ID Copied!')" class="w-full py-3 bg-white/10 hover:bg-white/20 rounded-xl text-xs font-bold transition-all flex items-center justify-center gap-2">
                        <i data-lucide="copy" class="w-4 h-4"></i> Copy ID
                    </button>
                </div>
            </div>

            <div class="bg-white rounded-[2.5rem] shadow-sm border border-slate-100 overflow-hidden">
                <div class="p-8 border-b border-slate-50">
                    <h3 class="font-bold text-xl text-slate-800 tracking-tight">Transaction Statement</h3>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-slate-50 text-slate-400 text-[10px] font-black uppercase tracking-widest">
                            <tr>
                                <th class="px-8 py-5">Activity</th>
                                <th class="px-8 py-5">Date</th>
                                <th class="px-8 py-5 text-right">Amount</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            <% if (ledgerEntries && ledgerEntries.length > 0) { %>
                                <% ledgerEntries.forEach(entry => { %>
                                    <tr class="hover:bg-slate-50/50 transition-all">
                                        <td class="px-8 py-6">
                                            <div class="flex items-center gap-4">
                                                <div class="p-2.5 rounded-xl <%= entry.type === 'DEBIT' ? 'bg-rose-50 text-rose-600' : 'bg-emerald-50 text-emerald-600' %>">
                                                    <i data-lucide="<%= entry.type === 'DEBIT' ? 'arrow-up-right' : 'arrow-down-left' %>" class="w-4 h-4"></i>
                                                </div>
                                                <div>
                                                    <p class="font-bold text-slate-800 text-sm"><%= entry.description || entry.type %></p>
                                                    <p class="text-[10px] text-slate-400 font-mono">Ref: <%= entry.transaction._id.toString().slice(-8) %></p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-8 py-6 text-sm text-slate-500 font-medium">
                                            <%= new Date(entry.createdAt).toLocaleDateString() %>
                                        </td>
                                        <td class="px-8 py-6 text-right font-black <%= entry.type === 'DEBIT' ? 'text-rose-600' : 'text-emerald-600' %>">
                                            <%= entry.type === 'DEBIT' ? '-' : '+' %>₹<%= entry.amount.toLocaleString() %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="3" class="px-8 py-20 text-center text-slate-400 italic">No activity recorded for this account.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>
</div>