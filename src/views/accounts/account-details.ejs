<div class="flex min-h-screen bg-[#f8fafc]">
    <%- include('../partials/sidebar') %>

    <div class="flex-1 flex flex-col">
        <%- include('../partials/navbar') %>

        <main class="p-8 max-w-4xl mx-auto w-full">
            <div class="mb-8 flex justify-between items-center">
                <div>
                    <h2 class="text-3xl font-bold text-slate-900 tracking-tight">Account Details</h2>
                    <p class="text-slate-500">Manage your specific account settings and limits.</p>
                </div>
                <a href="/dashboard" class="text-indigo-600 font-semibold flex items-center gap-2 hover:underline">
                    <i data-lucide="arrow-left" class="w-4 h-4"></i> Back to Dashboard
                </a>
            </div>

            <div class="relative group mb-10">
                <div class="absolute -inset-1 bg-gradient-to-r from-indigo-600 to-purple-600 rounded-[2rem] blur opacity-25 group-hover:opacity-50 transition duration-1000"></div>
                <div class="relative bg-gradient-to-br from-slate-900 to-slate-800 text-white p-10 rounded-[2rem] shadow-2xl overflow-hidden">
                    <div class="relative z-10 flex flex-col h-full justify-between">
                        <div class="flex justify-between items-start">
                            <div>
                                <p class="text-indigo-300 text-xs font-black uppercase tracking-[0.2em]">SkyBank Premium</p>
                                <h3 class="text-2xl font-bold mt-1 uppercase tracking-widest">Digital Account</h3>
                            </div>
                            <i data-lucide="contactless" class="w-8 h-8 text-indigo-400"></i>
                        </div>

                        <div class="mt-12">
                            <p class="text-slate-400 text-sm mb-1">Total Available Balance</p>
                            <h4 class="text-5xl font-black">₹<%= account.balance.toLocaleString() %></h4>
                        </div>

                        <div class="mt-12 flex justify-between items-end">
                            <div>
                                <p class="text-slate-500 text-[10px] uppercase font-bold tracking-widest mb-1">Account Holder</p>
                                <p class="font-bold tracking-wide"><%= user.name %></p>
                            </div>
                            <div class="text-right">
                                <p class="text-slate-500 text-[10px] uppercase font-bold tracking-widest mb-1">Account Number</p>
                                <p class="font-mono text-lg font-bold">**** **** <%= account._id.toString().slice(-4) %></p>
                            </div>
                        </div>
                    </div>
                    <div class="absolute -right-20 -bottom-20 w-64 h-64 bg-indigo-500/10 rounded-full blur-3xl"></div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm">
                    <div class="flex items-center gap-4 mb-4">
                        <div class="p-3 bg-emerald-50 text-emerald-600 rounded-2xl">
                            <i data-lucide="check-circle" class="w-6 h-6"></i>
                        </div>
                        <div>
                            <p class="text-sm text-slate-500 font-medium">Account Status</p>
                            <p class="font-bold text-slate-900 capitalize"><%= account.status %></p>
                        </div>
                    </div>
                </div>

                <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm">
                    <div class="flex items-center gap-4 mb-4">
                        <div class="p-3 bg-indigo-50 text-indigo-600 rounded-2xl">
                            <i data-lucide="calendar" class="w-6 h-6"></i>
                        </div>
                        <div>
                            <p class="text