<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
        <h2 class="text-xl font-bold mb-6">Internal Fund Transfer</h2>
        
        <form action="/api/tranctions/" method="POST" class="space-y-6">
            <div>
                <label class="block text-sm font-semibold mb-2 text-slate-600">From Account</label>
                <select name="fromAccount" class="w-full px-4 py-3 border rounded-xl appearance-none bg-slate-50">
                    <% accounts.forEach(acc => { %>
                        <option value="<%= acc._id %>">Account (...<%= acc._id.toString().slice(-4) %>) - Balance: ₹<%= acc.balance %></option>
                    <% }) %>
                </select>
            </div>

            <div>
                <label class="block text-sm font-semibold mb-2 text-slate-600">To Account (ID)</label>
                <input type="text" name="toAccount" placeholder="Enter Receiver's Account ID" required class="w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-blue-500 outline-none">
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-semibold mb-2 text-slate-600">Amount (INR)</label>
                    <input type="number" name="amount" min="1" required class="w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-blue-500 outline-none">
                </div>
                <div>
                    <label class="block text-sm font-semibold mb-2 text-slate-600">Reference/Key</label>
                    <input type="text" name="idempotencyKey" value="<%= Date.now() %>" readonly class="w-full px-4 py-3 border bg-slate-100 rounded-xl text-slate-500">
                </div>
            </div>

            <button type="submit" class="w-full bg-blue-600 text-white font-bold py-4 rounded-xl hover:bg-blue-700 transition shadow-lg flex justify-center items-center gap-2">
                <i data-lucide="shield-check" class="w-5 h-5"></i>
                Confirm Transaction
            </button>
        </form>
    </div>
</div>