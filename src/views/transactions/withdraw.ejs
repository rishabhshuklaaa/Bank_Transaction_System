<div class="flex min-h-screen">
    <%- include('../partials/sidebar') %>
    <div class="flex-1 p-8">
        <div class="max-w-xl mx-auto bg-white p-8 rounded-[2rem] shadow-sm border border-slate-100">
            <div class="mb-8 text-center">
                <div class="w-16 h-16 bg-rose-100 text-rose-600 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i data-lucide="arrow-up-from-line" class="w-8 h-8"></i>
                </div>
                <h2 class="text-2xl font-bold text-slate-900">Withdraw Cash</h2>
                <p class="text-slate-500">Securely withdraw funds from your account.</p>
            </div>

            <form action="/api/tranctions/" method="POST" data-remote class="space-y-6">
                <div>
                    <label class="block text-sm font-bold mb-2 text-slate-700">Withdraw From</label>
                    <select name="fromAccount" required class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none bg-slate-50">
                        <% accounts.forEach(acc => { %>
                            <option value="<%= acc._id %>">A/C: ....<%= acc._id.toString().slice(-4) %> (Balance: ₹<%= acc.balance %>)</option>
                        <% }) %>
                    </select>
                </div>

                <input type="hidden" name="toAccount" value="<%= accounts[0] ? accounts[0]._id : '' %>">

                <div>
                    <label class="block text-sm font-bold mb-2 text-slate-700">Amount (₹)</label>
                    <input type="number" name="amount" min="1" placeholder="Min. ₹100" required class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none">
                </div>

                <div>
                    <label class="block text-sm font-bold mb-2 text-slate-700">Withdrawal Key</label>
                    <input type="text" name="idempotencyKey" value="WTH-<%= Date.now() %>" readonly class="w-full px-4 py-3 border border-slate-100 bg-slate-50 text-slate-400 rounded-xl font-mono text-sm">
                </div>

                <button type="submit" class="w-full bg-rose-600 text-white font-bold py-4 rounded-2xl hover:bg-rose-700 transition shadow-lg flex justify-center items-center gap-2">
                    <i data-lucide="lock" class="w-5 h-5"></i>
                    Confirm Withdrawal
                </button>
            </form>
        </div>
    </div>
</div>